{
  "name": "y3-toolbox",
  "private": true,
  "version": "0.1.7",
  "description": "y3工具箱 for Y3 engine archive analysis workflows",
  "author": "BAIM",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "vite",
    "build": "tsc -b && vite build",
    "build:electron": "npm run build && electron-builder",
    "pack:win": "electron-builder --win --config electron-builder.yml",
    "postinstall": "node scripts/patch-7z-exit-code.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run --config vitest.config.js",
    "test:watch": "vitest --config vitest.config.js",
    "recovery": "npx tsx scripts/recovery-tool.ts"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/noto-sans-sc": "^5.2.9",
    "antd": "^6.3.3",
    "commander": "^14.0.3",
    "dayjs": "^1.11.20",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "esbuild": "^0.27.4",
    "papaparse": "^5.5.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tslib": "^2.8.1",
    "yauzl": "^3.4.0",
    "yazl": "^3.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.2",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/yazl": "^3.3.1",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^28.3.3",
    "electron-builder": "^26.8.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "tsx": "^4.22.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.1.0"
  }
}
